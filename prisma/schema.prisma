generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id             String            @id @default(uuid()) @db.Uuid
  name           String?
  description    String?
  status         CampaignStatus    @default(Draft)
  step           Int               @default(1)

  // Customise
  template       String?
  theme          String?
  channel        Channel?
  senderName     String?
  senderEmail    String?
  senderPhone    String?
  subject        String?
  previewText    String?
  messageContent String?           @db.Text

  // Recipients
  audienceType   AudienceType      @default(Custom)
  recipientCount Int               @default(0)
  recipients     CampaignRecipient[]

  // Delivery
  sendDate       DateTime?
  sendTime       String?
  timezone       String            @default("UTC")
  deliveryStatus DeliveryStatus    @default(Pending)

  // Payment
  budget         Decimal?          @db.Decimal(12, 2)
  cost           Decimal?          @db.Decimal(12, 2)
  paymentStatus  PaymentStatus     @default(Pending)

  // System
  isDraft        Boolean           @default(true)
  isDeleted      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([isDeleted])
}

model CampaignRecipient {
  id         String          @id @default(uuid()) @db.Uuid
  campaignId String          @db.Uuid
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  email      String?
  phone      String?
  name       String?
  status     RecipientStatus @default(Pending)

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([campaignId])
  @@index([status])
  @@index([email])
  @@index([phone])
}

enum CampaignStatus {
  Draft
  Scheduled
  Sent
  Completed
}

enum Channel {
  Email
  SMS
  Both
}

enum AudienceType {
  All
  Segment
  Custom
}

enum DeliveryStatus {
  Pending
  Scheduled
  Sent
  Failed
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
}

enum RecipientStatus {
  Pending
  Sent
  Failed
}

// ─── Gift Card Models ───────────────────────────────────────

model GiftCardCategory {
  id          Int      @id
  name        String   @unique
  description String?
  status      String   @default("Active")
  icon        String?

  programs    GiftCardProgramCategory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GiftCardProgram {
  id                   Int      @id
  referenceId          String   @unique
  name                 String
  giftCardProgramType  String   @default("Category")
  merchantId           Int      @default(0)
  displayAffiliationText Boolean @default(false)

  categories           GiftCardProgramCategory[]
  profiles             GiftCardProfile[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([referenceId])
}

model GiftCardProgramCategory {
  programId  Int
  categoryId Int

  program    GiftCardProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  category   GiftCardCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([programId, categoryId])
}

model GiftCardProfile {
  id                   Int      @id
  programId            Int
  program              GiftCardProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  name                 String
  referenceId          String   @unique
  colour               String?
  starOneColour        String?
  starTwoColour        String?
  lastFourDigitsColour String?
  frontsideImage       String?
  backsideImage        String?
  programProfileType   String   @default("Category")
  programProfileStatus String   @default("Active")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([programId])
  @@index([referenceId])
}
